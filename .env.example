# ─────────────────────────────────────────────────────────────────────
# Variables de entorno para docker-compose. Copia a `.env` y edita.
#
#   cp .env.example .env
#   nano .env
#
# Genera secrets fuertes:
#   openssl rand -hex 32        ← para passwords y JWT secrets
# ─────────────────────────────────────────────────────────────────────

# ── MySQL ──
DB_ROOT_PASSWORD=cambiar_root_password
DB_USER=webexams_user
DB_PASS=cambiar_user_password

# ── Auth ──
# JWT_SECRET debe ser idéntico en todos los servicios (lo comparten al validar tokens)
JWT_SECRET=cambiar_por_un_secret_fuerte_de_64_caracteres
JWT_EXPIRES_IN=1d

# SERVICE_SECRET autentica las llamadas internas entre microservicios
SERVICE_SECRET=cambiar_por_otro_secret_fuerte_distinto_al_jwt

# ── URL pública del frontend (para CORS y emails) ──
FRONTEND_URL=https://tu-dominio.com

# ── Firebase Admin SDK (backend Users) ──
# Genera en: Firebase Console → Project settings → Service accounts → Generate private key
# La PRIVATE_KEY DEBE ir entre comillas dobles y con \n literales, NO saltos de línea reales.
FIREBASE_PROJECT_ID=tu-proyecto-firebase
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@tu-proyecto.iam.gserviceaccount.com
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nXXXX\n-----END PRIVATE KEY-----\n"

# ── Resend (envío de calificaciones por email) ──
# Crea cuenta en https://resend.com y verifica tu dominio.
RESEND_API_KEY=re_tu_api_key_aqui
SMTP_FROM=noreply@tu-dominio-verificado.com
